{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd web-next && npm install --include=dev && npm run build",
  "devCommand": "cd web-next && npm install --include=dev && npm run dev",
  "installCommand": "npm install --no-package-lock --no-save --include=dev",
  "outputDirectory": "web-next/.next",
  "regions": ["icn1"],
  "functions": {
    "api/us-analysis.py": {
      "runtime": "@vercel/python@4.3.0",
      "maxDuration": 30,
      "excludeFiles": "{web-next/**,node_modules/**,data/**,book_images/**,migrations/**,scripts/**,.github/**,*.md,*.json,*.parquet,*.duckdb,*.csv,*.png}",
      "includeFiles": "app/**/*.py"
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-data",
      "schedule": "0 8 * * 1-5"
    },
    {
      "path": "/api/cron/weekly-scan",
      "schedule": "30 8 * * 5"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://accounts.google.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.github.com https://api.naver.com https://m.stock.naver.com https://api.stock.naver.com https://accounts.google.com; frame-src 'self' https://accounts.google.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://accounts.google.com; object-src 'none'"
        }
      ]
    }
  ]
}
