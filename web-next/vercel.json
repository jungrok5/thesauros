{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["icn1"],
  "crons": [
    {
      "_comment": "daily-data: 매일 17 KST. retention + bars + macro + investor_flow + DART disclosure alerts. 데이터 적재 + 이벤트 알림.",
      "path": "/api/cron/daily-data",
      "schedule": "0 8 * * 1-5"
    },
    {
      "_comment": "weekly-scan: 금요일 17 KST. scan_daily + telegram (enter/exit 결정 알림). 책 정신: 주봉 종가 후 1회.",
      "path": "/api/cron/weekly-scan",
      "schedule": "0 8 * * 5"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
