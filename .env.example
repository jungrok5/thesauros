# Copy this file to `.env` and fill in your secrets.
# `.env` is gitignored — never commit it.
#
# Used by Python cron + bot (app/db/* and app/data/*). The Next.js site
# reads its own variables from web-next/.env.local; see DEPLOY.md.

# ------------------------------------------------------------------
# Supabase (single source of truth)
# ------------------------------------------------------------------
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Optional: direct Postgres URL for migrations
# DATABASE_URL=postgres://postgres.<ref>:<password>@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres
SUPABASE_DB_PASSWORD=

# ------------------------------------------------------------------
# Market data sources
# ------------------------------------------------------------------
# FRED (Federal Reserve Economic Data) — https://fred.stlouisfed.org
FRED_API_KEY=

# SEC EDGAR — identifies you to SEC's fair-use rate limiter.
# Format: "<App or your name> <your-email>"
SEC_USER_AGENT=FinanceResearch your-email@example.com

# DART OpenAPI — Korean fundamental disclosures
# Register at https://opendart.fss.or.kr/  (free, 1000 req/min)
DART_API_KEY=

# KIS API — Korea Investment Securities (only for KIS-based ingest, e.g.
# app/db/ingest_investor_flow). Site quote is from Supabase bars_daily.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PROD_CODE=01
# `real` for live API, `vts` for paper-trading (모의투자)
KIS_ENV=real

# ------------------------------------------------------------------
# Telegram (alerts + self-link webhook)
# ------------------------------------------------------------------
# From @BotFather — one bot serves all users.
TELEGRAM_BOT_TOKEN=

# Shared secret between Vercel and (optional) long-poll bot.
# `openssl rand -hex 32`
TELEGRAM_LINK_SECRET=

# Required by Vercel's `/api/telegram/webhook` route. Registered with
# Telegram via setWebhook (see DEPLOY.md §5). `openssl rand -hex 32`
TELEGRAM_WEBHOOK_SECRET=

# Site URL used by the optional long-poll bot to call /api/telegram/consume.
# Not used in webhook mode.
WEB_BASE_URL=https://your-vercel-domain.vercel.app

# ------------------------------------------------------------------
# Web Push (PWA notifications)
# ------------------------------------------------------------------
# Generate with: python -m app.db.vapid_keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:you@example.com
