# Copy this file to `.env` and fill in your secrets.
# `.env` is gitignored — never commit it.

# FRED (Federal Reserve Economic Data)
# Register for a free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# SEC EDGAR — identifies you to SEC's fair-use rate limiter.
# Format: "<App or your name> <your-email>"
SEC_USER_AGENT=FinanceResearch your-email@example.com

# (Future) KIS API — Korea Investment Securities OpenAPI
# Add when ready:
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT_NO=

# (Future) Telegram bot for notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
